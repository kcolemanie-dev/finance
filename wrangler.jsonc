{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "finance-tracker",
  "main": "worker/index.js",
  "compatibility_date": "2026-03-13",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  },
  "vars": {
    "APP_NAME": "Finance Dashboard"
  }
}
